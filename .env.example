# ─── AI ───────────────────────────────────────────────
# OpenAI API key — used for Whisper transcription and gpt-4o-mini intent parsing.
# Without it, the app falls back to a smart regex parser so it still runs out of the box.
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"

# ─── Google (Calendar + Tasks) OAuth ──────────────────
# Create credentials at https://console.cloud.google.com (OAuth 2.0 Client ID).
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"
# Must match the redirect URI registered in Google Cloud Console.
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# ─── Notion ───────────────────────────────────────────
# Internal integration token from https://www.notion.so/my-integrations
NOTION_TOKEN="YOUR_NOTION_TOKEN"

# ─── Telegram bot (optional) ──────────────────────────
# Create a dedicated bot via @BotFather; do NOT reuse your main assistant bot.
TELEGRAM_IVOICE_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
# Your Telegram user/chat ID (the bot ignores all other chats for safety).
IVOICE_ALLOWED_CHAT_ID="YOUR_TELEGRAM_CHAT_ID"
# Base URL of the running iVoice server (used by the bot to call /api/shortcut).
IVOICE_URL="http://127.0.0.1:3002"
# Default transcription language passed to Whisper (ru / uk / en).
IVOICE_LANG="uk"

# ─── App security ─────────────────────────────────────
# Secret used to encrypt stored Google OAuth tokens at rest.
API_SECRET="A_LONG_RANDOM_STRING"
# Password to access the dashboard (cookie-based session auth).
DASHBOARD_PASSWORD="CHOOSE_A_PASSWORD"
# Token expected from the iOS Shortcut endpoint for quick voice capture.
SHORTCUT_TOKEN="A_LONG_RANDOM_STRING"
# Allowed origin for CORS (your deployed front-end URL).
CORS_ORIGIN="http://localhost:3000"
# Timezone for Google Calendar events and morning digest (IANA name).
TZ="Europe/Kyiv"
